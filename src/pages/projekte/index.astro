---
import type { SanityDocument } from '@sanity/client';
import { sanityClient } from 'sanity:client';
import { createImageUrlBuilder, type SanityImageSource } from '@sanity/image-url';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';

// Fetch from Sanity
const POSTS_QUERY = `*[_type == "post"]|order(publishedAt desc)[0...12]{
  _id, 
  title, 
  slug, 
  publishedAt,
  image
}`;

let sanityPosts: SanityDocument[] = [];
try {
  sanityPosts = await sanityClient.fetch<SanityDocument[]>(POSTS_QUERY);
  console.log('Sanity posts fetched:', sanityPosts.length, sanityPosts);
} catch (error) {
  console.error('Error fetching Sanity posts:', error);
}

// Fetch from local content collection
const localPosts = (await getCollection('portfolio')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
---

<Layout 
	title="Projekte"
	description="Explore our latest projects and work"
>
	<section class="py-16 sm:py-20">
		<div class="content-container">
			<div class="mb-12 sm:mb-16">
				<h1 class="text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl">
					Projekte
				</h1>
				<p class="mt-4 text-lg text-primary-950/70 dark:text-primary-200/70">
					Explore our latest projects and work
				</p>
			</div>
			
			<div class="grid gap-8 sm:gap-12 lg:grid-cols-2">
			{/* Local posts from content collection */}
			{
				localPosts.map((post) => (
					<article>
						<a
							href={`/projekte/${post.id}/`}
							class="group block"
						>
							{post.data.heroImage && (
								<div class="mb-4 overflow-hidden rounded-3xl h-[360px]">
									<Image
										width={720}
										height={360}
										src={post.data.heroImage}
										alt=""
										class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
									/>
								</div>
							)}
							<div class="flex flex-col gap-2">
								<span class="text-sm text-primary-600 dark:text-primary-400">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<h2 class="text-2xl sm:text-3xl font-medium tracking-tight transition group-hover:text-primary-600 dark:group-hover:text-primary-400">
									{post.data.title}
								</h2>
								<p class="text-primary-950/70 dark:text-primary-200/70">
									{post.data.description}
								</p>
							</div>
						</a>
					</article>
				))
			}
			
			{/* Sanity posts */}
			{
				sanityPosts.map((post) => {
					const postImageUrl = post.image
						? urlFor(post.image)?.width(720).height(360).url()
						: null;

					return (
						<article>
							<a
								href={`/projekte/cms/${post.slug.current}/`}
								class="group block"
							>
								{postImageUrl && (
									<div class="mb-4 overflow-hidden rounded-3xl h-[360px]">
										<img
											src={postImageUrl}
											alt={post.title}
											width={720}
											height={360}
											class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
										/>
									</div>
								)}
								<div class="flex flex-col gap-2">
									<span class="text-sm text-primary-600 dark:text-primary-400">
										<FormattedDate date={new Date(post.publishedAt)} />
									</span>
									<h2 class="text-2xl sm:text-3xl font-medium tracking-tight transition group-hover:text-primary-600 dark:group-hover:text-primary-400">
										{post.title}
									</h2>
								</div>
							</a>
						</article>
					);
				})
			}
		</div>
		</div>
	</section>
</Layout>
